# Copy this file to .env and fill in your own Supabase project's values.
# Find these under Project Settings > API in the Supabase dashboard.
# Never commit the real .env file — it's already in .gitignore.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Safe to expose client-side by design — this is a public key, the whole
# point of VAPID's public/private split. Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# (or use the pair already generated for you when this feature was built —
# see the push notifications section of README.md). Only the PUBLIC half
# goes here; the private half is a `supabase secrets set` on the
# send-push Edge Function, never in this file.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Only needed for the invite-client Edge Function, set via the Supabase CLI
# (`supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...`), NEVER in this file
# or anywhere that ships to the browser:
#   SUPABASE_SERVICE_ROLE_KEY
#   APP_URL   (your deployed app's URL, for invite email redirects)
#   VAPID_PRIVATE_KEY, VAPID_PUBLIC_KEY, VAPID_SUBJECT   (for send-push)
