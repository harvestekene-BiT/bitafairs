# Copy this file to .env and fill in your own Supabase project's values.
# Find these under Project Settings > API in the Supabase dashboard.
# Never commit the real .env file — it's already in .gitignore.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed for the invite-client Edge Function, set via the Supabase CLI
# (`supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...`), NEVER in this file
# or anywhere that ships to the browser:
#   SUPABASE_SERVICE_ROLE_KEY
#   APP_URL   (your deployed app's URL, for invite email redirects)
